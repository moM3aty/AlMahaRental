@model AlMahaRental.Models.Booking
@{
    ViewData["Title"] = "تم تأكيد الحجز";
}

<div class="container py-5 my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden text-center">
                <!-- Header -->
                <div class="bg-success text-white p-5 pb-4">
                    <i class="fa-regular fa-circle-check" style="font-size: 5rem; margin-bottom: 20px;"></i>
                    <h2 class="fw-bold mb-2">تم استلام طلب الحجز بنجاح!</h2>
                    <p class="mb-0 fs-5">شكراً لك لاختيارك شركة المها لتأجير السيارات.</p>
                </div>

                <!-- Body -->
                <div class="card-body p-5 bg-white">
                    <div class="mb-4 p-3 bg-light rounded-3 border border-dashed">
                        <p class="text-muted mb-1 fw-bold fs-6">رقم الحجز الخاص بك (المرجع)</p>
                        <h1 class="fw-bolder text-dark mb-0" style="letter-spacing: 2px;">@Model.BookingReference</h1>
                        <small class="text-danger mt-2 d-block"><i class="fa-solid fa-triangle-exclamation"></i> يرجى الاحتفاظ بهذا الرقم لتتبع حالة حجزك.</small>
                    </div>

                    <div class="row text-end g-3 border-bottom pb-4 mb-4">
                        <div class="col-6">
                            <span class="text-muted d-block mb-1">السيارة:</span>
                            <span class="fw-bold text-dark fs-5">@Model.Car?.Name</span>
                        </div>
                        <div class="col-6">
                            <span class="text-muted d-block mb-1">الإجمالي:</span>
                            <span class="fw-bold text-success fs-5">@Model.TotalPrice.ToString("0.00") ر.س</span>
                        </div>
                        <div class="col-6">
                            <span class="text-muted d-block mb-1">تاريخ الاستلام:</span>
                            <span class="fw-bold text-dark">@Model.PickupDate.ToString("yyyy-MM-dd")</span>
                        </div>
                        <div class="col-6">
                            <span class="text-muted d-block mb-1">تاريخ التسليم:</span>
                            <span class="fw-bold text-dark">@Model.ReturnDate.ToString("yyyy-MM-dd")</span>
                        </div>
                    </div>

                    <div class="alert alert-info border-0 rounded-3 text-start">
                        <i class="fa-solid fa-info-circle me-2"></i> حالة حجزك الحالية هي:
                        <strong class="text-primary ms-1">
                            @(Model.Status == "Pending" ? "قيد المراجعة" : Model.Status)
                        </strong>
                        <br>
                        سيتواصل معك فريقنا قريباً لتأكيد الحجز النهائي.
                    </div>

                    <div class="mt-5 d-flex justify-content-center gap-3">
                        <a href="/Home/Fleet" class="btn btn-outline-secondary rounded-pill px-4 fw-bold">
                            <i class="fa-solid fa-car me-2"></i> حجز سيارة أخرى
                        </a>
                        <a href="/" class="btn btn-primary rounded-pill px-4 fw-bold" style="background: var(--accent-gradient); border: none;">
                            <i class="fa-solid fa-home me-2"></i> العودة للرئيسية
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>