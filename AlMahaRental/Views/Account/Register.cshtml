@model AlMahaRental.Controllers.RegisterViewModel
@{
    ViewData["Title"] = "إنشاء حساب جديد";
    Layout = null; // نلغي الـ Layout لأن هذه الصفحة لها تصميم مستقل بالكامل
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>إنشاء حساب جديد - شركة المها</title>
    <link rel="stylesheet" href="~/css/all.min.css">
    <link rel="stylesheet" href="~/css/bootstrap.min.css">
    <link href="~/images/logo-1.jpg" rel="icon" type="image/x-icon" />
    
    <link rel="stylesheet" href="~/css/main.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@200..1000&display=swap" rel="stylesheet">
</head>
<body style="background-color: #f5f5f5;">
    <a asp-controller="Home" asp-action="Index" class="back-home-btn">
        <i class="fa-solid fa-arrow-right"></i>
        <span data-ar="العودة للرئيسية" data-en="Back to Home"> العودة للرئيسية</span>
    </a>

    <div class="d-flex justify-content-center align-items-center" style="min-height: 100vh; padding: 40px 0;">
        <div class="login-container">
            <div class="heading" data-ar="إنشاء حساب جديد" data-en="Sign Up">
                إنشاء حساب جديد
            </div>

            <form asp-action="Register" method="post" class="form">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold text-center"></div>

                <div class="row g-2">
                    <div class="col-6">
                        <input asp-for="FirstName" class="input" type="text" placeholder="الاسم الاول" data-ar="الاسم الاول" data-en="First Name">
                        <span asp-validation-for="FirstName" class="text-danger d-block mt-1 ms-2" style="font-size: 13px;"></span>
                    </div>
                    <div class="col-6">
                        <input asp-for="LastName" class="input" type="text" placeholder="الاسم الاخير" data-ar="الاسم الاخير" data-en="Last Name">
                        <span asp-validation-for="LastName" class="text-danger d-block mt-1 ms-2" style="font-size: 13px;"></span>
                    </div>
                </div>

                <input asp-for="PhoneNumber" class="input mt-2" type="tel" placeholder="رقم الهاتف" data-ar="رقم الهاتف" data-en="Phone Number">
                <span asp-validation-for="PhoneNumber" class="text-danger d-block mt-1 ms-2" style="font-size: 13px;"></span>

                <input asp-for="IdNumber" class="input mt-2" type="text" placeholder="رقم الهوية" data-ar="رقم الهوية" data-en="ID Number">
                <span asp-validation-for="IdNumber" class="text-danger d-block mt-1 ms-2" style="font-size: 13px;"></span>

                <input asp-for="Password" class="input mt-2" type="password" placeholder="الرقم السري" data-ar="الرقم السري" data-en="Password">
                <span asp-validation-for="Password" class="text-danger d-block mt-1 ms-2" style="font-size: 13px;"></span>

                <input asp-for="ConfirmPassword" class="input mt-2" type="password" placeholder="تأكيد الرقم السري" data-ar="تأكيد الرقم السري" data-en="Confirm Password">
                <span asp-validation-for="ConfirmPassword" class="text-danger d-block mt-1 ms-2" style="font-size: 13px;"></span>

                <button type="submit" class="login-button mt-4" data-ar="انشاء حساب جديد" data-en="Create New Account">انشاء حساب جديد</button>

                <div class="d-flex justify-content-between align-items-center mt-3">
                    <span class="forgot-password" data-ar="لديك حساب بالفعل؟" data-en="Already have an account?">لديك حساب بالفعل؟</span>
                    <span class="sign-in">
                        <a asp-action="Login" data-ar="تسجيل الدخول" data-en="Sign In">تسجيل الدخول</a>
                    </span>
                </div>
            </form>
        </div>
    </div>

    <script src="~/js/bootstrap.bundle.min.js"></script>
</body>
</html>