@model AlMahaRental.Controllers.LoginViewModel
@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = null; // نلغي الـ Layout لأن صفحة تسجيل الدخول لها تصميم مستقل بالكامل
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تسجيل الدخول - شركة المها</title>
    <link rel="stylesheet" href="~/css/all.min.css">
    <link rel="stylesheet" href="~/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/main.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@200..1000&display=swap" rel="stylesheet">
</head>
<body style="background-color: #f5f5f5;">
    <a asp-controller="Home" asp-action="Index" class="back-home-btn">
        <i class="fa-solid fa-arrow-right"></i>
        <span data-ar="العودة للرئيسية" data-en="Back to Home"> العودة للرئيسية</span>
    </a>

    <div class="d-flex justify-content-center align-items-center" style="min-height: 100vh;">
        <div class="login-container">
            <div class="heading" data-ar="تسجيل الدخول" data-en="Login">
                تسجيل الدخول
            </div>

            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="form">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold text-center"></div>

                <input asp-for="IdNumber" class="input" type="text" placeholder="رقم الهوية" data-ar="رقم الهوية" data-en="ID Number">
                <span asp-validation-for="IdNumber" class="text-danger d-block mt-1 ms-2" style="font-size: 13px;"></span>

                <input asp-for="Password" class="input" type="password" placeholder="الرقم السري" data-ar="الرقم السري" data-en="Password">
                <span asp-validation-for="Password" class="text-danger d-block mt-1 ms-2" style="font-size: 13px;"></span>

                <div class="d-flex justify-content-between align-items-center mt-3">
                    <span class="forgot-password">
                        <a href="#" data-ar="نسيت كلمة المرور ؟" data-en="Forgot Password?">نسيت كلمة المرور ؟ </a>
                    </span>
                    <span class="sign-up">
                        <a asp-action="Register" data-ar="انشاء حساب جديد" data-en="Create New Account">انشاء حساب جديد</a>
                    </span>
                </div>

                <button type="submit" class="login-button" data-ar="تسجيل الدخول" data-en="Login">تسجيل الدخول</button>
            </form>

           
        </div>
    </div>

    <script src="~/js/bootstrap.bundle.min.js"></script>
</body>
</html>