@model AlMahaRental.Controllers.LoginViewModel
@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = null; // نلغي الـ Layout لأن صفحة تسجيل الدخول لها تصميم مستقل بالكامل
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تسجيل الدخول - شركة المها</title>
    <link rel="stylesheet" href="~/css/all.min.css">
    <link rel="stylesheet" href="~/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/main.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@200..1000&display=swap" rel="stylesheet">
</head>
<body style="background-color: #f5f5f5;">
    <a asp-controller="Home" asp-action="Index" class="back-home-btn">
        <i class="fa-solid fa-arrow-right"></i>
        <span data-ar="العودة للرئيسية" data-en="Back to Home"> العودة للرئيسية</span>
    </a>

    <div class="d-flex justify-content-center align-items-center" style="min-height: 100vh;">
        <div class="login-container">
            <div class="heading" data-ar="تسجيل الدخول" data-en="Login">
                تسجيل الدخول
            </div>

            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="form">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold text-center"></div>

                <input asp-for="IdNumber" class="input" type="text" placeholder="رقم الهوية" data-ar="رقم الهوية" data-en="ID Number">
                <span asp-validation-for="IdNumber" class="text-danger d-block mt-1 ms-2" style="font-size: 13px;"></span>

                <input asp-for="Password" class="input" type="password" placeholder="الرقم السري" data-ar="الرقم السري" data-en="Password">
                <span asp-validation-for="Password" class="text-danger d-block mt-1 ms-2" style="font-size: 13px;"></span>

                <div class="d-flex justify-content-between align-items-center mt-3">
                    <span class="forgot-password">
                        <a href="#" data-ar="نسيت كلمة المرور ؟" data-en="Forgot Password?">نسيت كلمة المرور ؟ </a>
                    </span>
                    <span class="sign-up">
                        <a asp-action="Register" data-ar="انشاء حساب جديد" data-en="Create New Account">انشاء حساب جديد</a>
                    </span>
                </div>

                <button type="submit" class="login-button" data-ar="تسجيل الدخول" data-en="Login">تسجيل الدخول</button>
            </form>

            <div class="social-account-container">
                <span class="title" data-ar="أو تسجيل الدخول بواسطة" data-en="Or login with">أو تسجيل الدخول بواسطة</span>
                <div class="social-accounts">
                    <button class="social-button google">
                        <svg class="svg" xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 0 488 512">
                            <path d="M488 261.8C488 403.3 391.1 504 248 504 110.8 504 0 393.2 0 256S110.8 8 248 8c66.8 0 123 24.5 166.3 64.9l-67.5 64.9C258.5 52.6 94.3 116.6 94.3 256c0 86.5 69.1 156.6 153.7 156.6 98.2 0 135-70.4 140.8-106.9H248v-85.3h236.1c2.3 12.7 3.9 24.9 3.9 41.4z"></path>
                        </svg>
                    </button>
                    <button class="social-button apple">
                        <svg class="svg" xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 0 384 512">
                            <path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"></path>
                        </svg>
                    </button>
                    <button class="social-button twitter">
                        <svg class="svg" xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 0 512 512">
                            <path d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8L200.7 275.5 26.8 48H172.4L272.9 180.9 389.2 48zM364.4 421.8h39.1L151.1 88h-42L364.4 421.8z"></path>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="~/js/bootstrap.bundle.min.js"></script>
</body>
</html>