<section class="services-section py-5">
    <div class="container">
        <div class="heading text-center d-flex flex-column gap-3 mb-5 justify-content-center align-items-center">

            <span data-ar="خدماتنا" data-en="Our Services">
                خدماتنا
            </span>

            <h2 data-ar="اكتشف المجموعة الشاملة من خدمات تأجير السيارات الفاخرة التي تقدمها شركة المها"
                data-en="Discover the full range of luxury car rental services offered by Almaha Company">
                اكتشف المجموعة الشاملة من خدمات تأجير السيارات الفاخرة التي تقدمها شركة المها
            </h2>

        </div>
        <div class="row g-4">

            <div class="col-md-6 col-lg-4">
                <div class="services-card">
                    <div class="img">
                        <img src="~/images/service-1.jpg" class="img-fluid rounded-2" alt="service image">
                    </div>

                    <h3 data-ar="تأجير سيارات بمدة قصيرة (يومي / أسبوعي)"
                        data-en="Short-Term Car Rental (Daily / Weekly)">
                        تأجير سيارات بمدة قصيرة (يومي / أسبوعي)
                    </h3>

                    <p class="text-muted fw-semibold"
                       data-ar="مرونة عالية لتلبية الاحتياجات الفورية، سواء للسياحة، الزيارات العائلية، أو التنقلات اليومية خيارات متنوعة من السيارات الاقتصادية، العائلية، والفاخرة"
                       data-en="High flexibility to meet immediate needs, whether for tourism, family visits, or daily commuting. A variety of economy, family, and luxury cars are available.">
                        مرونة عالية لتلبية الاحتياجات الفورية، سواء للسياحة، الزيارات العائلية، أو التنقلات
                        اليومية خيارات متنوعة من السيارات الاقتصادية، العائلية، والفاخرة
                    </p>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="services-card">
                    <div class="img">
                        <img src="~/images/service-2.jpg" class="img-fluid rounded-2" alt="service image">
                    </div>

                    <h3 data-ar="تأجير سيارات بمدة طويلة (شهري / سنوي)"
                        data-en="Long-Term Car Rental (Monthly / Yearly)">
                        تأجير سيارات بمدة طويلة (شهري / سنوي)
                    </h3>

                    <p class="text-muted fw-semibold"
                       data-ar="حلول مثالية للشركات والمؤسسات التي تحتاج لأسطول سيارات دون أعباء التملك والصيانة عقود مخصصة تتناسب مع الميزانية والاحتياجات التشغيلية خدمات صيانة شاملة وتأمين خلال فترة العقد"
                       data-en="Ideal solutions for companies and organizations needing a fleet of cars without ownership and maintenance burdens. Customized contracts to match budget and operational needs, with comprehensive maintenance and insurance during the contract period.">
                        حلول مثالية للشركات والمؤسسات التي تحتاج لأسطول سيارات دون أعباء التملك والصيانة عقود
                        مخصصة تتناسب مع الميزانية والاحتياجات التشغيلية خدمات صيانة شاملة وتأمين خلال فترة العقد
                    </p>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="services-card">
                    <div class="img">
                        <img src="~/images/service3.jpg" class="img-fluid rounded-2" alt="service image">
                    </div>

                    <h3 data-ar="تأجير سيارات للشركات" data-en="Corporate Car Rental">
                        تأجير سيارات للشركات
                    </h3>

                    <p class="text-muted fw-semibold"
                       data-ar="برامج تأجير مصممة خصيصا لقطاع الأعمال، تشمل أساطيل سيارات للموظفين، النقل التنفيذي أو لأغراض المشاريع إمكانية توفير سائقين محترفين عند الطلب"
                       data-en="Rental programs designed specifically for the business sector, including employee fleets, executive transport, or project purposes. Professional drivers can be provided upon request.">
                        برامج تأجير مصممة خصيصا لقطاع الأعمال، تشمل أساطيل سيارات للموظفين، النقل التنفيذي
                        أو لأغراض المشاريع إمكانية توفير سائقين محترفين عند الطلب
                    </p>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="services-card">
                    <div class="img">
                        <img src="~/images/service-4.jpg" class="img-fluid rounded-2" alt="service image">
                    </div>

                    <h3 data-ar="تأجير سيارات مع سائق" data-en="Car Rental with Driver">
                        تأجير سيارات مع سائق
                    </h3>

                    <p class="text-muted fw-semibold"
                       data-ar="خدمة راقية ومريحة للمسافرين ورجال الأعمال وكبار الشخصيات سائقون ذوو خبرة ومعرفة بالطرق، ملتزمون بالمواعيد والاحترافية"
                       data-en="A premium and comfortable service for travelers, businesspeople, and VIPs. Experienced drivers with road knowledge, punctual and professional.">
                        خدمة راقية ومريحة للمسافرين ورجال الأعمال وكبار الشخصيات
                        سائقون ذوو خبرة ومعرفة بالطرق، ملتزمون بالمواعيد والاحترافية
                    </p>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="services-card">
                    <div class="img">
                        <img src="~/images/service-5.jpg" class="img-fluid rounded-2" alt="service image">
                    </div>

                    <h3 data-ar="خدمات المطار (الاستلام والتسليم)"
                        data-en="Airport Services (Pickup & Drop-off)">
                        خدمات المطار (الاستلام والتسليم)
                    </h3>

                    <p class="text-muted fw-semibold"
                       data-ar="تسهيل عملية وصول ومغادرة عملائنا من وإلى جميع المطارات الرئيسية في المملكة خدمة توصيل واستلام السيارة من باب المطار أو الفندق لتوفير الوقت والجهد"
                       data-en="Facilitating the arrival and departure of our clients to and from all major airports in the Kingdom. Car pickup and drop-off service from the airport or hotel to save time and effort.">
                        تسهيل عملية وصول ومغادرة عملائنا من وإلى جميع المطارات الرئيسية في المملكة
                        خدمة توصيل واستلام السيارة من باب المطار أو الفندق لتوفير الوقت والجهد
                    </p>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="services-card">
                    <div class="img">
                        <img src="~/images/service-6.jpg" class="img-fluid rounded-2" alt="service image">
                    </div>

                    <h3 data-ar="تأجير سيارات فخمة ورياضية" data-en="Luxury & Sports Car Rental">
                        تأجير سيارات فخمة ورياضية
                    </h3>

                    <p class="text-muted fw-semibold"
                       data-ar="للمناسبات الخاصة، الفعاليات، أو لمن يبحث عن تجربة قيادة مميزة وفاخرة تشكيلة من أحدث وأفخم موديلات السيارات تأجير سيارات الدفع الرباعي والمركبات العائلية الكبيرة مثالية للرحلات الطويلة، العائلات الكبيرة، أو للطرق الوعرة توفر مساحة وراحة إضافية"
                       data-en="For special occasions, events, or for those seeking a unique and luxurious driving experience. A collection of the latest and most luxurious car models, including 4x4s and large family vehicles. Ideal for long trips, large families, or rough roads, offering extra space and comfort.">
                        للمناسبات الخاصة، الفعاليات، أو لمن يبحث عن تجربة قيادة مميزة وفاخرة
                        تشكيلة من أحدث وأفخم موديلات السيارات
                        تأجير سيارات الدفع الرباعي والمركبات العائلية الكبيرة
                        مثالية للرحلات الطويلة، العائلات الكبيرة، أو للطرق الوعرة
                        توفر مساحة وراحة إضافية
                    </p>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="services-card">
                    <div class="img">
                        <img src="~/images/service-7.jpg" class="img-fluid rounded-2" alt="service image">
                    </div>

                    <h3 data-ar="خدمات المساعدة على الطريق" data-en="Roadside Assistance Services">
                        خدمات المساعدة على الطريق
                    </h3>

                    <p class="text-muted fw-semibold"
                       data-ar="دعم متواصل على مدار الساعة لضمان راحة وسلامة عملائنا المساعدة في حالات الأعطال الحوادث، أو أي طارئ على الطريق تأمين شامل"
                       data-en="24/7 support to ensure our clients’ comfort and safety. Assistance in case of breakdowns, accidents, or any roadside emergencies. Comprehensive insurance included.">
                        دعم متواصل على مدار الساعة لضمان راحة وسلامة عملائنا
                        المساعدة في حالات الأعطال الحوادث، أو أي طارئ على الطريق
                        تأمين شامل
                    </p>
                </div>
            </div>

        </div>
    </div>
</section>

<section class="service-section py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold mt-2" data-ar="حلول تأجير مرنة تناسب احتياجاتك الشخصية والتجارية"
                data-en="Flexible rental solutions tailored to your personal and business needs">
                حلول تأجير مرنة تناسب احتياجاتك الشخصية والتجارية
            </h2>
        </div>
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="service-box">
                    <div class="icon-circle">
                        <i class="fas fa-car-side"></i>
                    </div>
                    <div class="number">01</div>

                    <h3 data-ar="تأجير الأفراد" data-en="Individual Rentals">
