}

<section class="services-header">
    <div class="container pt-5">

        <h2 data-ar="خدماتنا" data-en="Our Services">
            خدماتنا
        </h2>

        <div class="fw-semibold">

            <a href="/Home/Index" data-ar="الرئيسية" data-en="Home">
                الرئيسية
            </a>

            <span>/</span>

            <span data-ar="خدماتنا" data-en="Our Services">
                خدماتنا
            </span>

        </div>

