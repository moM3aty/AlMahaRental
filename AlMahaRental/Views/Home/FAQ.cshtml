@{
    ViewData["Title"] = "الأسئلة الشائعة";
}

<section class="faq-section container-fluid">
    <div class="faq-wrapper mx-auto p-5">

        <div class="row g-4 align-items-center justify-content-center mt-5">

            <div class="col-lg-8">
                <p class="text-purple fw-bold small mb-2" data-ar="✱ الأسئلة الشائعة"
                   data-en="✱ Frequently Asked Questions">
                    ✱ الأسئلة الشائعة
                </p>

                <h2 class="title" data-ar="كل ما تحتاج لمعرفته حول خدماتنا"
                    data-en="Everything You Need to Know About Our Services">
                    كل ما تحتاج لمعرفته
                    حول خدماتنا
                </h2>

                <div class="accordion custom-faq" id="faqAccordion">

                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button d-flex align-items-center justify-content-between"
                                    type="button" data-bs-toggle="collapse" data-bs-target="#faq1">

                                <span data-ar="ما أنواع السيارات التي تقدمونها؟"
                                      data-en="What types of cars do you offer?">
                                    ما أنواع السيارات التي تقدمونها؟
                                </span>

                                <span class="faq-icon">
                                    <i class="fas fa-chevron-down"></i>
                                </span>

                            </button>
                        </h2>
                        <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-muted fw-semibold"
                                 data-ar="نوفر في المفتاح لتأجير السيارات مجموعة متنوعة تناسب الاحتياجات اليومية والرحلات العائلية والسيارات الفاخرة."
                                 data-en="Almaha Car Rental offers a wide variety of vehicles suitable for daily needs, family trips, and luxury cars.">
                                نوفر في المفتاح لتأجير السيارات مجموعة متنوعة تناسب الاحتياجات اليومية والرحلات
                                العائلية والسيارات الفاخرة.
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed d-flex align-items-center justify-content-between"
                                    type="button" data-bs-toggle="collapse" data-bs-target="#faq2">

                                <span data-ar="ما هي المستندات المطلوبة لاستئجار سيارة؟"
                                      data-en="What documents are required to rent a car?">
                                    ما هي المستندات المطلوبة لاستئجار سيارة؟
                                </span>

                                <span class="faq-icon">
                                    <i class="fas fa-chevron-down"></i>
                                </span>

                            </button>
                        </h2>
                        <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-muted fw-semibold"
                                 data-ar="رخصة قيادة سارية، هوية وطنية أو إقامة، وبطاقة دفع."
                                 data-en="A valid driving license, national ID or residence permit, and a payment card.">
                                رخصة قيادة سارية، هوية وطنية أو إقامة، وبطاقة دفع.
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed d-flex align-items-center justify-content-between"
                                    type="button" data-bs-toggle="collapse" data-bs-target="#faq3">

                                <span data-ar="هل تقبلون العملاء الدوليين؟"
                                      data-en="Do you accept international customers?">
                                    هل تقبلون العملاء الدوليين؟
                                </span>

                                <span class="faq-icon">
                                    <i class="fas fa-chevron-down"></i>
                                </span>

                            </button>
                        </h2>
                        <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-muted fw-semibold"
                                 data-ar="نعم، نرحب بالعملاء الدوليين مع توفر المستندات المطلوبة."
                                 data-en="Yes, we welcome international customers with the required documents.">
                                نعم، نرحب بالعملاء الدوليين مع توفر المستندات المطلوبة.
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>