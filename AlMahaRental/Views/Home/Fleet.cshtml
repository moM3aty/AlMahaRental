@model IEnumerable<AlMahaRental.Models.Car>
@{
    ViewData["Title"] = "أسطول المها";

    // استخراج السنوات والفئات المتاحة في قاعدة البيانات لتكون الفلاتر ديناميكية 100%
    var availableYears = Model?.Select(c => c.Year).Distinct().OrderByDescending(y => y).ToList() ?? new List<int>();
    var availableCategories = Model?.Select(c => c.Category).Distinct().ToList() ?? new List<string>();
}
<style>
    .fa-solid {
        color: #fff !important;
    }
</style>
<section class="fleet-section">
    <div class="container pt-5">
        <div class="heading text-center d-flex flex-column gap-3 mb-5 justify-content-center align-items-center pt-5">
            <span data-ar="أسطولنا" data-en="Our Fleet">أسطولنا</span>
            <h2 class="text-center text-dark" data-ar="استكشف أسطولنا المثالي والواسع" data-en="Explore Our Perfect and Extensive Fleet">
                استكشف أسطولنا المثالي والواسع
            </h2>
        </div>

        <!-- فلاتر البحث الديناميكية -->
        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="filter-box shadow-sm border p-3 rounded-3 bg-white">
                    <label class="mb-2 text-dark fw-bold" data-ar="سنة الصنع" data-en="Manufacturing Year"><i class="fa-regular fa-calendar text-primary me-1"></i> سنة الصنع</label>
                    <select class="form-select border-0 bg-light" id="yearFilter">
                        <option value="all" data-ar="الكل" data-en="All">الكل</option>
                        @foreach (var year in availableYears)
                        {
                            <option value="@year">@year</option>
                        }
                    </select>
                </div>
            </div>
            <div class="col-md-4">
                <div class="filter-box shadow-sm border p-3 rounded-3 bg-white">
                    <label class="mb-2 text-dark fw-bold" data-ar="فئة السيارة" data-en="Car Category"><i class="fa-solid fa-layer-group text-primary me-1"></i> فئة السيارة</label>
                    <select class="form-select border-0 bg-light" id="categoryFilter">
                        <option value="all" data-ar="الكل" data-en="All">الكل</option>
                        @foreach (var cat in availableCategories)
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                </div>
            </div>
            <div class="col-md-4">
                <div class="filter-box shadow-sm border p-3 rounded-3 bg-white">
                    <label class="mb-2 text-dark fw-bold" data-ar="ترتيب السعر" data-en="Sort Price"><i class="fa-solid fa-sort text-primary me-1"></i> ترتيب السعر</label>
                    <select class="form-select border-0 bg-light" id="priceSort">
                        <option value="" data-ar="الترتيب الافتراضي" data-en="Default Sorting">الترتيب الافتراضي</option>
                        <option value="low" data-ar="من الأرخص للأغلى" data-en="Low to High">من الأرخص للأغلى</option>
                        <option value="high" data-ar="من الأغلى للأرخص" data-en="High to Low">من الأغلى للأرخص</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- عرض السيارات من الداتا بيز -->
        <div class="row g-4 mb-5 pb-5 cars-section show" id="carsContainer">
            @if (Model != null && Model.Any())
            {
                foreach (var car in Model)
                {
                    <div class="col-lg-4 col-md-6 car-item"
                         data-category="@car.Category"
                         data-price="@car.DailyPrice.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                         data-year="@car.Year"
                         data-available="@car.IsAvailable.ToString().ToLower()">

                        <div class="nova-card shadow-sm @(!car.IsAvailable ? "unavailable" : "")">
                            @if (car.IsAvailable)
                            {
                                <span class="badge-offer" data-ar="متاح للحجز" data-en="Available">متاح للحجز</span>
                            }
                            else
                            {
                                <span class="badge-offer bg-danger" data-ar="غير متاح" data-en="Unavailable">غير متاح</span>
                            }

                            <div class="nova-img" style="height: 220px; overflow: hidden; background-color: #fff;">
                                <img src="@car.ImageUrl" alt="@car.Name" style="width: 100%; height: 100%; object-fit: contain;">
                            </div>

                            <div class="nova-content">
                                <span class="nova-badge">@car.Category</span>
                                <h5 class="nova-title mb-4">@car.Name - @car.Year</h5>

                                <!-- المواصفات -->
                                <div class="features d-flex justify-content-between align-items-center text-center my-3">
                                    <div>
                                        <i class="fa-solid fa-users fs-4 mb-2 text-muted" style="color: #8392a5 !important;"></i>
                                        <p class="mt-2 text-purple fw-bold">@car.Passengers</p>
                                    </div>
                                    <div>
                                        <i class="fa-solid fa-door-open fs-4 mb-2 text-muted" style="color: #8392a5 !important;"></i>
                                        <p class="mt-2 text-purple fw-bold">@car.Doors</p>
                                    </div>
                                    <div>
                                        <i class="fa-solid fa-suitcase fs-4 mb-2 text-muted" style="color: #8392a5 !important;"></i>
                                        <p class="mt-2 text-purple fw-bold">@car.Bags</p>
                                    </div>
                                    <div>
                                        <i class="fa-solid fa-gear fs-4 mb-2 text-muted" style="color: #8392a5 !important;"></i>
                                        <p class="mt-2 text-purple fw-bold">@car.Transmission</p>
                                    </div>
                                </div>

                                <div class="pricing-section bg-light p-3 rounded-3 mt-3 mb-4">
                                    <div class="daily-price d-flex justify-content-between align-items-center border-bottom pb-2 mb-2">
                                        <span class="price-label fw-bold text-dark">الإيجار اليومي</span>
                                        <div>
                                            <span class="fw-bolder text-success fs-5">@car.DailyPrice.ToString("0") ر.س</span>
                                        </div>
                                    </div>
                                    <div class="weekly-price d-flex justify-content-between align-items-center">
                                        <span class="weekly-label fw-bold text-dark">الإيجار الشهري</span>
                                        <div>
                                            <span class="final-price fw-bolder text-primary fs-5">@car.MonthlyPrice.ToString("0") ر.س</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="text-center mt-3">
                                    @if (car.IsAvailable)
                                    {
                                        <a href="/Booking/Reserve/@car.Id" class="btn book-btn w-100 py-3 fw-bold fs-5 shadow-sm" data-ar="احجز الآن" data-en="Book Now">احجز الآن</a>
                                    }
                                    else
                                    {
                                        <button class="btn book-btn btn-unavailable w-100 py-3 fw-bold fs-5" style="background: #e9ecef; color: #6c757d;" disabled data-ar="محجوزة حالياً" data-en="Currently Booked">محجوزة حالياً</button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <h4 class="text-muted">لا توجد سيارات متاحة حالياً.</h4>
                </div>
            }

            <!-- رسالة تظهر عبر الجافاسكريبت إذا لم تتطابق الفلاتر مع أي سيارة -->
            <div class="col-12 text-center py-5 w-100" id="noCarsMessage" style="display: none;">
                <i class="fa-solid fa-car-tunnel fs-1 text-muted mb-3 opacity-50"></i>
                <h4 class="text-muted">لا توجد سيارات تطابق خيارات البحث الخاصة بك.</h4>
                <button class="btn btn-outline-primary mt-3 rounded-pill px-4" onclick="resetFilters()">إعادة ضبط البحث</button>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const yearFilter = document.getElementById('yearFilter');
            const categoryFilter = document.getElementById('categoryFilter');
            const priceSort = document.getElementById('priceSort');
            const noCarsMessage = document.getElementById('noCarsMessage');

            // نحتفظ بنسخة من جميع كروت السيارات
            const carItems = Array.from(document.querySelectorAll('.car-item'));

            // نعطي كل سيارة رقم ترتيبها الأصلي لكي نتمكن من العودة إليه لاحقاً
            carItems.forEach((car, index) => {
                car.setAttribute('data-index', index);
            });

            function filterAndSortCars() {
                const yearVal = yearFilter.value;
                const categoryVal = categoryFilter.value;
                const sortVal = priceSort.value;

                let visibleCars = [];

                // 1. تطبيق الفلاتر (السنة والفئة)
                carItems.forEach(car => {
                    const carYear = car.getAttribute('data-year');
                    const carCat = car.getAttribute('data-category');

                    const matchYear = (yearVal === 'all' || carYear === yearVal);
                    const matchCat = (categoryVal === 'all' || carCat === categoryVal);

                    if (matchYear && matchCat) {
                        car.style.display = ''; // نرجعه للشكل الطبيعي
                        visibleCars.push(car);
                    } else {
                        car.style.display = 'none'; // إخفاء السيارة
                    }
                });

                // 2. تطبيق الترتيب باستخدام خاصية الـ order الخاصة بـ CSS Flexbox
                if (sortVal === 'low') {
                    visibleCars.sort((a, b) => parseFloat(a.getAttribute('data-price')) - parseFloat(b.getAttribute('data-price')));
                } else if (sortVal === 'high') {
                    visibleCars.sort((a, b) => parseFloat(b.getAttribute('data-price')) - parseFloat(a.getAttribute('data-price')));
                } else {
                    // الترتيب الافتراضي
                    visibleCars.sort((a, b) => parseInt(a.getAttribute('data-index')) - parseInt(b.getAttribute('data-index')));
                }

                // تطبيق الترتيب الجديد على الـ DOM
                visibleCars.forEach((car, index) => {
                    car.style.order = index;
                });

                // 3. إظهار رسالة عدم وجود نتائج في حال عدم التطابق
                if(visibleCars.length === 0 && carItems.length > 0) {
                    noCarsMessage.style.display = 'block';
                    noCarsMessage.style.order = 9999; // جعل الرسالة في نهاية القائمة دائماً
                } else {
                    noCarsMessage.style.display = 'none';
                }
            }

            // الاستماع لتغييرات المستخدم وتطبيق الفلتر فوراً
            yearFilter.addEventListener('change', filterAndSortCars);
            categoryFilter.addEventListener('change', filterAndSortCars);
            priceSort.addEventListener('change', filterAndSortCars);

            // دالة لإعادة الضبط يدوياً
            window.resetFilters = function() {
                yearFilter.value = 'all';
                categoryFilter.value = 'all';
                priceSort.value = '';
                filterAndSortCars();
            };
        });
    </script>
}