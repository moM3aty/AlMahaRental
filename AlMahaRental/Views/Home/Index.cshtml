@{
    ViewData["Title"] = "الرئيسية";
}

@using AlMahaRental.Data
@inject ApplicationDbContext _context
@{
    // جلب البيانات ديناميكياً للرئيسية
    var topCars = _context.Cars.Where(c => c.IsAvailable).Take(6).ToList();
    var allCars = _context.Cars.Where(c => c.IsAvailable).ToList();
    var branchLocations = _context.BranchLocations.ToList();
}

<!-- 1. Hero Header Slider -->
<header class="hero-header">
    <div class="swiper headerSwiper">
        <div class="swiper-wrapper">
            <div class="swiper-slide">
                <div class="slide-bg" style="background-image: url('/images/slider-1.png');"></div>
                <div class="container h-100 d-flex align-items-center justify-content-center">
                    <div class="hero-content text-white">
                        <h3 class="heading-title" data-ar="مرحبا بك في شركة المها" data-en="Welcome to Al Maha Company">
                            مرحبا بك في شركة المها
                        </h3>
                        <h1 class="display-4 fw-bolder" data-ar="هل ترغب في توفير المزيد على استئجار سيارتك؟" data-en="Do you want to save more on your car rental?">
                            هل ترغب في توفير المزيد على استئجار سيارتك؟
                        </h1>
                        <p class="mx-auto" data-ar="سواء كنت تخطط لعطلة نهاية أسبوع، أو رحلة عمل، أو تحتاج فقط إلى سيارة موثوقة ليوم واحد، نحن نوفر لك مجموعة واسعة من السيارات التي تناسب جميع احتياجاتك." data-en="Whether you are planning a weekend, a business trip, or just need a reliable car for a day, we provide a wide range of cars to suit all your needs.">
                            سواء كنت تخطط لعطلة نهاية أسبوع، أو رحلة عمل، أو تحتاج فقط إلى سيارة موثوقة ليوم واحد، نحن نوفر لك مجموعة واسعة من السيارات التي تناسب جميع احتياجاتك.
                        </p>
                        <div class="d-flex flex-wrap gap-3 justify-content-center align-items-center">
                            <a asp-controller="Home" asp-action="Services" class="btn btn-main mt-3" data-ar="اكتشف الخدمات" data-en="Discover Services">اكتشف الخدمات</a>
                            <a asp-controller="Home" asp-action="AboutUs" class="btn btn-second mt-3" data-ar="تعلم المزيد" data-en="Learn More">تعلم المزيد</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="swiper-slide">
                <div class="slide-bg" style="background-image: url('/images/slider-2.jpg');"></div>
                <div class="container h-100 d-flex align-items-center justify-content-center">
                    <div class="hero-content text-white">
                        <h3 class="heading-title" data-ar="أسطول متنوع وحديث" data-en="Diverse and Modern Fleet">
                            أسطول متنوع وحديث
                        </h3>
                        <h1 class="display-4 fw-bolder" data-ar="اختر السيارة المناسبة لرحلتك بكل سهولة" data-en="Choose the Right Car for Your Trip Easily">
                            اختر السيارة المناسبة لرحلتك بكل سهولة
                        </h1>
                        <p class="mx-auto" data-ar="نقدم لك مجموعة متنوعة من السيارات الاقتصادية والفاخرة والعائلية لتناسب جميع احتياجاتك سواء داخل المدينة أو للسفر لمسافات طويلة." data-en="We offer you a wide range of economy, luxury, and family cars to suit all your needs, whether inside the city or for long-distance travel.">
                            نقدم لك مجموعة متنوعة من السيارات الاقتصادية والفاخرة والعائلية لتناسب جميع احتياجاتك سواء داخل المدينة أو للسفر لمسافات طويلة.
                        </p>
                        <div class="d-flex flex-wrap gap-3 justify-content-center align-items-center">
                            <a asp-controller="Home" asp-action="Fleet" class="btn btn-main mt-3" data-ar="عرض السيارات" data-en="View Cars">عرض السيارات</a>
                            <a href="#manageReserve" class="btn btn-second mt-3" data-ar="احجز الآن" data-en="Book Now">احجز الآن</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="swiper-slide">
                <div class="slide-bg" style="background-image: url('/images/slider-3.png');"></div>
                <div class="container h-100 d-flex align-items-center justify-content-center">
                    <div class="hero-content text-white">
                        <h3 class="heading-title" data-ar="أفضل الأسعار والعروض" data-en="Best Prices and Offers">
                            أفضل الأسعار والعروض
                        </h3>
                        <h1 class="display-4 fw-bolder" data-ar="استمتع بعروض حصرية وخصومات مميزة" data-en="Enjoy Exclusive Deals and Special Discounts">
                            استمتع بعروض حصرية وخصومات مميزة
                        </h1>
                        <p class="mx-auto" data-ar="احصل على أفضل قيمة مقابل المال مع عروضنا الخاصة وخدمة عملاء متاحة على مدار الساعة لضمان راحتك الكاملة." data-en="Get the best value for your money with our special offers and 24/7 customer service to ensure your complete comfort.">
                            احصل على أفضل قيمة مقابل المال مع عروضنا الخاصة وخدمة عملاء متاحة على مدار الساعة لضمان راحتك الكاملة.
                        </p>
                        <div class="d-flex flex-wrap gap-3 justify-content-center align-items-center">
                            <a asp-controller="Home" asp-action="Offers" class="btn btn-main mt-3" data-ar="اطلع على العروض" data-en="View Offers">اطلع على العروض</a>
                            <a asp-controller="Home" asp-action="ContactUs" class="btn btn-second mt-3" data-ar="تواصل معنا" data-en="Contact Us">تواصل معنا</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>

<!-- 2. Booking Section -->
<section class="booking">
    <div class="booking-container py-3">
        <div class="container-fluid">
            <div class="row g-4 ">
                <div class="col-lg-6 justify-content-start">
                    <div class="booking-content">
                        <div class="tab-buttons">
                            <button class="tab-btn active" data-tab="daily" data-ar="يومي" data-en="Daily">
                                يومي
                            </button>
                            <button class="tab-btn" data-tab="weekly" data-ar="اسبوعي" data-en="Weekly">
                                اسبوعي
                            </button>
                            <button class="tab-btn" data-tab="monthly" data-ar="فليكس ( للتأجير الشهري )"
                                    data-en="Flex (Monthly Rental)">
                                فليكس ( للتأجير الشهري )
                            </button>
                        </div>

                        <!-- الفورم الديناميكي مع الاستايل الأصلي 100% -->
                        <form id="homeBookingForm" class="booking-form">
                            <div class="row g-4 daily-reserve">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label data-ar="موقع الاستلام" data-en="Pickup Location">موقع الاستلام</label>
                                        <div class="input-wrapper location-wrapper">
                                            <i class="fas fa-map-marker-alt"></i>
                                            <input type="text" class="form-control location-input" name="PickupLocation"
                                                   id="pickupLocation" placeholder="اختر فرع الاستلام"
                                                   data-ar-placeholder="اختر فرع الاستلام"
                                                   data-en-placeholder="Select Pickup Branch">
                                            <div class="mega-location-dropdown">
                                                <div class="mega-container">
                                                    <div class="mega-categories">
                                                        <div class="mega-category active" data-type="branches"
                                                             data-ar="فروعنا المتاحة" data-en="Our Branches">
                                                            فروعنا المتاحة
                                                        </div>
                                                    </div>
                                                    <div class="mega-branches">
                                                        <!-- جلب الفروع من قاعدة البيانات للاستايل الأصلي -->
                                                        @if (branchLocations != null)
                                                        {
                                                            foreach (var loc in branchLocations)
                                                            {
                                                                <div class="mega-branch-item" data-name="@loc.Name"
                                                                     data-hours="متاح حسب الفرع"
                                                                     data-location="@loc.Name"
                                                                     data-ar="@loc.Name" data-en="@loc.Name">
                                                                    @loc.Name
                                                                </div>
                                                            }
                                                        }
                                                    </div>
                                                    <div class="mega-info">
                                                        <h6 data-ar="توقيت الفرع" data-en="Branch Hours">توقيت الفرع</h6>
                                                        <p id="branchHours" data-ar="اختر فرع لعرض التفاصيل"
                                                           data-en="Select a branch to view details">
                                                            اختر فرع لعرض التفاصيل
                                                        </p>

                                                        <h6 data-ar="موقع الفرع" data-en="Branch Location">موقع الفرع</h6>
                                                        <p id="branchLocation" data-ar="---" data-en="---">---</p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group drop-off-group">
                                        <label data-ar="موقع التسليم" data-en="Drop-off Location">موقع التسليم</label>
                                        <div class="input-wrapper location-wrapper">
                                            <i class="fas fa-map-marker-alt"></i>
                                            <input type="text" class="form-control location-input" name="DropoffLocation"
                                                   id="dropoffLocation" placeholder="اختر فرع التوصيل"
                                                   data-ar-placeholder="اختر فرع التوصيل"
                                                   data-en-placeholder="Select Drop-off Branch">
                                            <div class="mega-location-dropdown">
                                                <div class="mega-container">
                                                    <div class="mega-categories">
                                                        <div class="mega-category active" data-type="branches"
                                                             data-ar="فروعنا المتاحة" data-en="Our Branches">
                                                            فروعنا المتاحة
                                                        </div>
                                                    </div>
                                                    <div class="mega-branches">
                                                        <!-- جلب الفروع من قاعدة البيانات للاستايل الأصلي -->
                                                        @if (branchLocations != null)
                                                        {
                                                            foreach (var loc in branchLocations)
                                                            {
                                                                <div class="mega-branch-item" data-name="@loc.Name"
                                                                     data-hours="متاح حسب الفرع"
                                                                     data-location="@loc.Name"
                                                                     data-ar="@loc.Name" data-en="@loc.Name">
                                                                    @loc.Name
                                                                </div>
                                                            }
                                                        }
                                                    </div>
                                                    <div class="mega-info">
                                                        <h6 data-ar="توقيت الفرع" data-en="Branch Hours">توقيت الفرع</h6>
                                                        <p id="branchHours" data-ar="اختر فرع لعرض التفاصيل"
                                                           data-en="Select a branch to view details">
                                                            اختر فرع لعرض التفاصيل
                                                        </p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label data-ar="تاريخ الاستلام" data-en="Pickup Date">تاريخ الاستلام</label>
                                        <div class="input-wrapper">
                                            <i class="fas fa-calendar"></i>
                                            <input type="text" class="form-control date-picker" id="pickup-date" name="PickupDate"
                                                   placeholder="00/00/0000" data-ar-placeholder="00/00/0000"
                                                   data-en-placeholder="00/00/0000">
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label data-ar="وقت الاستلام" data-en="Pickup Time">وقت الاستلام</label>
                                        <div class="input-wrapper">
                                            <i class="fas fa-clock"></i>
                                            <input type="text" class="form-control" placeholder="00:00"
                                                   data-ar-placeholder="00:00" data-en-placeholder="00:00">
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label data-ar="تاريخ التسليم" data-en="Return Date">تاريخ التسليم</label>
                                        <div class="input-wrapper">
                                            <i class="fas fa-calendar"></i>
                                            <input type="text" class="form-control date-picker" id="return-date" name="ReturnDate"
                                                   placeholder="00/00/0000" data-ar-placeholder="00/00/0000"
                                                   data-en-placeholder="00/00/0000">
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group duration-group">
                                        <label data-ar="وقت التسليم" data-en="Return Time">وقت التسليم</label>
                                        <div class="input-wrapper">
                                            <i class="fas fa-clock"></i>
                                            <input type="text" class="form-control" placeholder="00:00"
                                                   data-ar-placeholder="00:00" data-en-placeholder="00:00">
                                        </div>
                                    </div>
                                </div>

                                <!-- حقل اختيار السيارة بالستايل الأصلي -->
                                <div class="col-md-12">
                                    <div class="form-group">
                                        <label data-ar="اختر السيارة (اختياري)" data-en="Select Car (Optional)">اختر السيارة (اختياري)</label>
                                        <div class="input-wrapper">
                                            <i class="fas fa-car"></i>
                                            <select id="homeSelectedCar" class="form-control" style="appearance: none; -webkit-appearance: none; cursor: pointer;">
                                                <option value="" selected data-ar="-- تصفح جميع السيارات (الأسطول) --" data-en="-- Browse All Cars (Fleet) --">-- تصفح جميع السيارات (الأسطول) --</option>
                                                @if (allCars != null)
                                                {
                                                    foreach (var car in allCars)
                                                    {
                                                        <option value="@car.Id">@car.Name - @car.Year (@car.DailyPrice.ToString("0") ر.س/يوم)</option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6 month-reserve" style="display: none;">
                                    <div class="form-group">
                                        <label data-ar="المده" data-en="Duration">المده</label>
                                        <div class="input-wrapper">
                                            <i class="fas fa-clock"></i>
                                            <input type="text" class="form-control" placeholder="شهر مايو"
                                                   data-ar-placeholder="شهر مايو" data-en-placeholder="May Month">
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <button type="submit" class="btn-next text-decoration-none text-center"
                                    data-ar="بحث" data-en="Search">
                                بحث
                            </button>
                        </form>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="row g-4 p-3 justify-content-center">
                        <div class="d-flex gap-3 align-items-center mb-4 justify-content-center">
                            <div class="d-flex align-items-center justify-content-center gap-1 ">
                                <span class="block w-20 h-px bg-primary"></span>
                                <span class="block h-20 w-px bg-primary"></span>
                                <span class="block h-30 w-px bg-primary"></span>
                            </div>
                            <h2 data-ar="استئجار سيارة في ثلاث خطوات بسيطة"
                                data-en="Rent a Car in 3 Simple Steps">
                                استئجار سيارة في ثلاث خطوات بسيطة
                            </h2>
                            <div class="d-flex gap-2 align-items-center">
                                <div class="d-flex align-items-center justify-content-center gap-1 ">
                                    <span class="block h-30 w-px bg-primary"></span>
                                    <span class="block h-20 w-px bg-primary"></span>
                                    <span class="block w-20 h-px bg-primary"></span>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="book-card">
                                <div class="icon">
                                    <i class="fa-solid fa-car-side"></i>
                                </div>
                                <h3>
                                    <span class="text-purple">01.</span>
                                    <span data-ar="اختر سيارتك واحجز" data-en="Choose Your Car and Book">
                                        اختر سيارتك واحجز
                                    </span>
                                </h3>
                                <p class="text-muted fw-semibold"
                                   data-ar="حدد التواريخ ومكان الاستلام، واستعرض تشكيلتنا المتنوعة من السيارات."
                                   data-en="Select your dates and pickup location, and browse our diverse car collection.">
                                    حدد التواريخ ومكان الاستلام، واستعرض تشكيلتنا المتنوعة من السيارات.
                                </p>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="book-card">
                                <div class="icon">
                                    <i class="fa-solid fa-credit-card"></i>
                                </div>
                                <h3>
                                    <span class="text-purple">02.</span>
                                    <span data-ar="تأكيد الحجز والدفع" data-en="Confirm Booking & Payment">
                                        تأكيد الحجز والدفع
                                    </span>
                                </h3>
                                <p class="text-muted fw-semibold"
                                   data-ar="قم بإتمام حجزك بسهولة وأمان عبر الإنترنت مع تسعير شفاف يشمل جميع التكاليف."
                                   data-en="Complete your booking easily and securely online with transparent pricing covering all costs.">
                                    قم بإتمام حجزك بسهولة وأمان عبر الإنترنت مع تسعير شفاف يشمل جميع التكاليف.
                                </p>
                            </div>
                        </div>
                        <div class="col-lg-7">
                            <div class="book-card">
                                <div class="icon">
                                    <i class="fa-solid fa-map-location-dot"></i>
                                </div>
                                <h3>
                                    <span class="text-purple">03.</span>
                                    <span data-ar="استلام السيارة والانطلاق" data-en="Pick Up the Car & Go">
                                        استلام السيارة والانطلاق
                                    </span>
                                </h3>
                                <p class="text-muted fw-semibold"
                                   data-ar="قدّم رخصة القيادة وتأكيد الحجز في مكتبنا، ثم انطلق بثقة نحو وجهتك."
                                   data-en="Present your driving license and booking confirmation at our office, then confidently head to your destination.">
                                    قدّم رخصة القيادة وتأكيد الحجز في مكتبنا، ثم انطلق بثقة نحو وجهتك.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 3. Cards Section -->
<section class="cards bg-white">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-4">
                <a asp-controller="Home" asp-action="Services" class="card card-1 text-decoration-none">
                    <h2 data-ar="خدماتنا" data-en="Our Services">
                        خدماتنا
                    </h2>
                    <div class="icon">
                        <i class="fas fa-arrow-right"></i>
                    </div>
                </a>
            </div>
            <div class="col-lg-4">
                <a asp-controller="Home" asp-action="Offers" class="card card-2 text-decoration-none">
                    <h2 data-ar="العروض" data-en="Offers">
                        العروض
                    </h2>
                    <div class="icon">
                        <i class="fas fa-arrow-right"></i>
                    </div>
                </a>
            </div>
            <div class="col-lg-4">
                <a asp-controller="Home" asp-action="Fleet" class="card card-3 text-decoration-none">
                    <h2 data-ar="حجز السيارات" data-en="Car Booking">
                        حجز السيارات
                    </h2>
                    <div class="icon">
                        <i class="fas fa-arrow-right"></i>
                    </div>
                </a>
            </div>

            <!-- إدارة الحجز -->
            <div class="row g-4 mt-5 align-items-center" id="manageReserve">
                <div class="col-lg-8">
                    <div class="content">
                        <p class="text-muted fw-semibold lh-lg"
                           data-ar="تقدم لكم شركة المها لتأجير السيارات أحدث وأفضل أنواع السيارات لتجعل رحلتك أكثر راحة وأمانًا. إذا كنت تبحث عن سيارة للإيجار سواء كانت جديدة أو بحالة ممتازة، فقط أخبرنا بما تحتاج إليه وسنوفّره لك بكل سهولة. نحن في المها نضع رضا عملائنا على رأس أولوياتنا، ونسعى دائمًا لتقديم مجموعة متكاملة من الخدمات التي تلبي مختلف الاحتياجات والتطلعات. نوفر أسطولًا متنوعًا من السيارات التي تناسب جميع الأذواق وأنماط الحياة، بأسعار تنافسية وعروض مميزة. كما نقدم خدماتنا في مختلف أنحاء المملكة العربية السعودية، مع التزام كامل بتقديم خدمة عملاء احترافية وسريعة الاستجابة. هدفنا هو كسب ثقة عملائنا من خلال الجودة، الشفافية، والاهتمام بأدق التفاصيل. مع المها… راحتك هي أولويتنا، ورضاك هو نجاحنا."
                           data-en="Al Maha Car Rental offers you the latest and best types of cars to make your journey more comfortable and safe. Whether you are looking for a car for rent, new or in excellent condition, just tell us what you need and we will provide it easily. At Al Maha, customer satisfaction is our top priority, and we always strive to provide a comprehensive range of services that meet various needs and expectations. We offer a diverse fleet of cars to suit all tastes and lifestyles, at competitive prices and special offers. We also provide our services across Saudi Arabia, with full commitment to professional and responsive customer service. Our goal is to earn our customers' trust through quality, transparency, and attention to the finest details. With Al Maha… your comfort is our priority, and your satisfaction is our success.">
                            تقدم لكم شركة المها لتأجير السيارات أحدث وأفضل أنواع السيارات لتجعل رحلتك أكثر راحة وأمانًا.
                            إذا كنت تبحث عن سيارة للإيجار سواء كانت جديدة أو بحالة ممتازة، فقط أخبرنا بما تحتاج إليه
                            وسنوفّره لك بكل سهولة.
                            نحن في المها نضع رضا عملائنا على رأس أولوياتنا، ونسعى دائمًا لتقديم مجموعة متكاملة من
