                data-en="Explore Our Perfect and Extensive Fleet">
                استكشف أسطولنا المثالي والواسع
            </h2>
        </div>
        <div class="swiper fleetSwiper py-5">
            <div class="swiper-wrapper">
                @if (topCars.Any())
                {
                    @foreach (var car in topCars)
                    {
                        <div class="swiper-slide">
                            <div class="nova-card">
                                <span class="badge-offer" data-ar="عروض خاصة" data-en="Special Offers">عروض خاصة</span>
                                <div class="nova-img" style="height: 200px; overflow: hidden;">
                                    <img src="@car.ImageUrl" alt="@car.Name" style="width: 100%; height: 100%; object-fit: cover;">
                                </div>
                                <div class="nova-content">

                                    <span class="nova-badge">@car.Category</span>

                                    <h5 class="nova-title mb-5">
                                        @car.Name - @car.Year
                                    </h5>

                                    <div class="features d-flex justify-content-between align-items-center text-center my-3">
                                        <div>
                                            <img src="~/images/icon-1.png" alt="">
                                            <p class="mt-2 text-purple">@car.Passengers</p>
                                        </div>
                                        <div>
                                            <img src="https://demo.awaikenthemes.com/novaride/dark/wp-content/uploads/2024/09/icon-door-1.svg" alt="">
                                            <p class="mt-2 text-purple">@car.Doors</p>
                                        </div>
                                        <div>
                                            <img src="~/images/icon-2.png" alt="">
                                            <p class="mt-2 text-purple">@car.Bags</p>
                                        </div>
                                        <div>
                                            <img src="~/images/icon-3.png" alt="">
                                            <p class="mt-2 text-purple">@car.Transmission</p>
                                        </div>
                                    </div>

                                    <div class="nova-footer">
                                        <p class="price text-center">
                                            @car.DailyPrice.ToString("0.00") ر.س / يوم
                                            <small class="text-purple d-block" data-ar="(قبل خصم الولاء)" data-en="(Before Loyalty Discount)">
                                                (قبل خصم الولاء)
                                            </small>
                                        </p>

                                        <div class="text-center">
                                            <a href="/Booking/Reserve/@car.Id" class="btn book-btn" data-ar="احجز الآن" data-en="Book Now">
                                                احجز الآن
                                            </a>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center text-white w-100">
                        <h5>يتم تحديث أسطول السيارات حالياً. يرجى زيارة الصفحة لاحقاً.</h5>
                    </div>
                }
            </div>
        </div>
        <div class="d-flex justify-content-center align-items-center">
            <a asp-action="Fleet" class="btn book-btn" data-ar="تصفح جميع السيارات" data-en="Browse All Cars">
                تصفح جميع السيارات
            </a>
        </div>
    </div>
</section>

