<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - شركة المها لتأجير السيارات</title>
    <link rel="stylesheet" href="~/css/all.min.css">
    <link rel="stylesheet" href="~/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="~/css/main.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@200..1000&display=swap" rel="stylesheet">
</head>
<body>

    <header class="main-header">
        <div class="container-fluid">
            <div class="header-content">
                <div class="header-right">
                    <button class="menu-toggle" id="menuToggle">
                        <div class="hamburger">
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                        <span class="menu-text" data-ar="القائمة" data-en="Menu">القائمة</span>
                    </button>
                </div>
                <div class="header-center">
                    <div class="logo">
                        <a asp-controller="Home" asp-action="Index">
                            <img src="~/images/logo-1.jpg" class="img-fluid" alt="المها لتأجير السيارات">
                        </a>
                    </div>
                </div>
                <div class="header-left pb-3 pb-lg-0">
                    <a class="btn-booking text-decoration-none" href="/#manageReserve">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M5.5 7a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1h-5zM5 9.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5zm0 2a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5z" />
                            <path d="M9.5 0a.5.5 0 0 1 .5.5.5.5 0 0 0 .5.5.5.5 0 0 1 .5.5V2a.5.5 0 0 1-.5.5h-5A.5.5 0 0 1 5 2v-.5a.5.5 0 0 1 .5-.5.5.5 0 0 0 .5-.5.5.5 0 0 1 .5-.5h3z" />
                            <path d="M3 2.5a.5.5 0 0 1 .5-.5H4a.5.5 0 0 0 0-1h-.5A1.5 1.5 0 0 0 2 2.5v12A1.5 1.5 0 0 0 3.5 16h9a1.5 1.5 0 0 0 1.5-1.5v-12A1.5 1.5 0 0 0 12.5 1H12a.5.5 0 0 0 0 1h.5a.5.5 0 0 1 .5.5v12a.5.5 0 0 1-.5.5h-9a.5.5 0 0 1-.5-.5v-12z" />
                        </svg>
                        <span data-ar="إدارة الحجوزات" data-en="Booking Management">إدارة الحجوزات</span>
                    </a>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <a class="btn-login text-decoration-none" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                            <i class="fa-solid fa-user-circle me-1"></i>
                            <span data-ar="حسابي" data-en="My Account">حسابي</span>
                        </a>
                    }
                    else
                    {
                        <a class="btn-login text-decoration-none" href="/Identity/Account/Login">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z" />
                            </svg>
                            <span data-ar="تسجيل دخول" data-en="Login">تسجيل دخول</span>
                        </a>
                    }

                    <button class="btn-lang" id="langToggle">
                        <img src="https://flagcdn.com/w40/us.png" id="langFlag" width="20">
                        <span data-ar="English" data-en="العربية">English</span>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    <div class="sidebar-menu" id="sidebarMenu">
        <button class="sidebar-close" id="sidebarClose">
            <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="currentColor" viewBox="0 0 16 16">
                <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z" />
            </svg>
        </button>

        <nav class="sidebar-nav">
            <a asp-controller="Home" asp-action="Index" class="nav-item">
                <i class="fa-solid fa-home"></i>
                <span data-ar="الصفحة الرئيسية" data-en="Home">الصفحة الرئيسية</span>
            </a>
            <a asp-controller="Home" asp-action="Fleet" class="nav-item">
                <i class="fa-solid fa-car"></i>
                <span data-ar="أسطول المها" data-en="Al Maha Fleet">أسطول المها</span>
            </a>
            <a asp-controller="Home" asp-action="Services" class="nav-item">
                <i class="fa-solid fa-gem"></i>
                <span data-ar="الخدمات" data-en="Services">الخدمات</span>
            </a>
            <a asp-controller="Home" asp-action="AboutUs" class="nav-item">
                <i class="fa-solid fa-info-circle"></i>
                <span data-ar="معلومات عنا" data-en="About Us">معلومات عنا</span>
            </a>
            <a asp-controller="Home" asp-action="ContactUs" class="nav-item">
                <i class="fa-solid fa-envelope"></i>
                <span data-ar="إتصل بنا" data-en="Contact Us">إتصل بنا</span>
            </a>
        </nav>
    </div>

    <main>
        @RenderBody()
    </main>

    <footer>
        <div class="footer-top">
            <div class="container">
                <div class="row g-4 text-end">
                    <div class="col-md-2">
                        <div class="footer-title" data-ar="عن الشركة" data-en="About Us">عن الشركة</div>
                        <a asp-controller="Home" asp-action="AboutUs" class="footer-link" data-ar="معلومات عنا" data-en="About Us">معلومات عنا</a>
                        <a asp-controller="Home" asp-action="ContactUs" class="footer-link" data-ar="إتصل بنا" data-en="Contact Us">إتصل بنا</a>
                    </div>
                    <div class="col-md-2">
                        <div class="footer-title" data-ar="الخدمات" data-en="Services">الخدمات</div>
                        <a asp-controller="Home" asp-action="Services" class="footer-link" data-ar="الخدمات" data-en="Services">الخدمات</a>
                        <a asp-controller="Home" asp-action="Fleet" class="footer-link" data-ar="أسطول المها" data-en="Our Fleet">أسطول المها</a>
                    </div>
                    <div class="col-md-3">
                        <div class="footer-title" data-ar="تابعنا على وسائل التواصل الاجتماعي" data-en="Follow Us on Social Media">
                            تابعنا على وسائل التواصل الاجتماعي
                        </div>
                        <div class="social-icons mb-3">
                            <a href="#"><i class="fab fa-instagram"></i></a>
                            <a href="#"><i class="fab fa-linkedin-in"></i></a>
                            <a href="#"><i class="fab fa-facebook-f"></i></a>
                            <a href="#"><i class="fab fa-x-twitter"></i></a>
                        </div>
                        <div class="footer-title mt-4" data-ar="حمل تطبيقنا" data-en="Download Our App">حمل تطبيقنا</div>
                        <div class="store-btn d-flex flex-wrap gap-2">
                            <img src="~/images/applestore.png">
                            <img src="~/images/google.png">
                            <img src="~/images/huawei.png">
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="container">
                <div class="row g-4 align-items-center p-3">
                    <div class="col-lg-6 text-end copyright" data-ar="حقوق الملكية @DateTime.Now.Year. جميع الحقوق محفوظة لشركة المها لتأجير السيارات." data-en="© @DateTime.Now.Year All rights reserved by Al Maha Car Rental.">
                        حقوق الملكية @DateTime.Now.Year. جميع الحقوق محفوظة لشركة المها لتأجير السيارات.
                    </div>
                    <div class="col-lg-6 justify-content-between payment-logos">
                        <img src="~/images/footer-logos.png">
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <a href="https://wa.me/966509234799" class="whatsapp-float" target="_blank">
        <i class="fab fa-whatsapp"></i>
    </a>

    <script src="~/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="~/js/main.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>