@model AlMahaRental.Models.Car
@{
    ViewData["Title"] = "إضافة سيارة جديدة";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold" style="color: var(--text-main);">إضافة سيارة جديدة للأسطول</h2>
    <a asp-action="Index" class="btn btn-secondary rounded-pill px-4">
        <i class="fa-solid fa-arrow-right me-2"></i> عودة للقائمة
    </a>
</div>

<div class="premium-card p-5">
    <form asp-action="Create" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-4">
            <!-- بيانات أساسية -->
            <div class="col-md-6">
                <label asp-for="Name" class="form-label fw-bold">اسم السيارة / الموديل <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control form-control-lg bg-light border-0" placeholder="مثال: شفروليه ماليبو" required />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Category" class="form-label fw-bold">الفئة <span class="text-danger">*</span></label>
                <select asp-for="Category" class="form-select form-select-lg bg-light border-0" required>
                    <option value="">-- اختر الفئة --</option>
                    <option value="اقتصادية">اقتصادية</option>
                    <option value="صغيرة">صغيرة</option>
                    <option value="عائلية">عائلية</option>
                    <option value="فخمة">فخمة</option>
                    <option value="دفع رباعي">دفع رباعي</option>
                </select>
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Year" class="form-label fw-bold">سنة الصنع <span class="text-danger">*</span></label>
                <input asp-for="Year" class="form-control form-control-lg bg-light border-0" type="number" min="2010" max="2026" required />
                <span asp-validation-for="Year" class="text-danger"></span>
            </div>

            <div class="col-12"><hr class="text-muted opacity-25"></div>

            <!-- الأسعار -->
            <div class="col-md-4">
                <label asp-for="DailyPrice" class="form-label fw-bold">السعر اليومي (ر.س) <span class="text-danger">*</span></label>
                <input asp-for="DailyPrice" class="form-control form-control-lg bg-light border-0" type="number" step="0.01" required />
                <span asp-validation-for="DailyPrice" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="MonthlyPrice" class="form-label fw-bold">السعر الشهري (ر.س) <span class="text-danger">*</span></label>
                <input asp-for="MonthlyPrice" class="form-control form-control-lg bg-light border-0" type="number" step="0.01" required />
                <span asp-validation-for="MonthlyPrice" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="OpenMileagePrice" class="form-label fw-bold">سعر العداد المفتوح (ر.س) <span class="text-danger">*</span></label>
                <input asp-for="OpenMileagePrice" class="form-control form-control-lg bg-light border-0" type="number" step="0.01" required />
                <span asp-validation-for="OpenMileagePrice" class="text-danger"></span>
            </div>

            <div class="col-12"><hr class="text-muted opacity-25"></div>

            <!-- المواصفات -->
            <div class="col-md-3">
                <label asp-for="Passengers" class="form-label fw-bold">عدد الركاب</label>
                <input asp-for="Passengers" class="form-control form-control-lg bg-light border-0" type="number" value="4" />
            </div>
            <div class="col-md-3">
                <label asp-for="Doors" class="form-label fw-bold">عدد الأبواب</label>
                <input asp-for="Doors" class="form-control form-control-lg bg-light border-0" type="number" value="4" />
            </div>
            <div class="col-md-3">
                <label asp-for="Bags" class="form-label fw-bold">عدد الحقائب</label>
                <input asp-for="Bags" class="form-control form-control-lg bg-light border-0" type="number" value="2" />
            </div>
            <div class="col-md-3">
                <label asp-for="Transmission" class="form-label fw-bold">ناقل الحركة</label>
                <select asp-for="Transmission" class="form-select form-select-lg bg-light border-0">
                    <option value="اتوماتيك">اتوماتيك</option>
                    <option value="عادي">عادي</option>
                </select>
            </div>

            <div class="col-12"><hr class="text-muted opacity-25"></div>

            <!-- الصورة والحالة -->
            <div class="col-md-6">
                <label class="form-label fw-bold">صورة السيارة</label>
                <input type="file" name="imageFile" class="form-control form-control-lg bg-light border-0" accept="image/*" />
                <small class="text-muted mt-1 d-block">سيتم استخدام صورة افتراضية إذا لم تقم برفع صورة.</small>
            </div>
            <div class="col-md-6 d-flex align-items-center">
                <div class="form-check form-switch ms-3 mt-4">
                    <input class="form-check-input form-check-input-lg" style="transform: scale(1.5); margin-left: 15px;" type="checkbox" asp-for="IsAvailable" checked>
                    <label class="form-check-label fw-bold fs-5" asp-for="IsAvailable">السيارة متاحة للحجز؟</label>
                </div>
            </div>

            <!-- زر الحفظ -->
            <div class="col-12 text-end mt-5">
                <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm" style="background: var(--accent-gradient); border: none;">
                    <i class="fa-solid fa-save me-2"></i> حفظ بيانات السيارة
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}