@model IEnumerable<AlMahaRental.Models.Car>
@{
    ViewData["Title"] = "إدارة السيارات";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold" style="color: var(--text-main);">السيارات المتاحة في الأسطول</h2>
    <a asp-action="Create" class="btn btn-primary" style="background: var(--accent-gradient); border: none; border-radius: 10px; padding: 10px 20px;">
        <i class="fa-solid fa-plus me-2"></i> إضافة سيارة جديدة
    </a>
</div>

<div class="premium-card p-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th scope="col" class="ps-4">السيارة</th>
                    <th scope="col">النوع / الفئة</th>
                    <th scope="col">السعر اليومي</th>
                    <th scope="col">السعر الشهري</th>
                    <th scope="col">الحالة</th>
                    <th scope="col" class="text-center">الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <img src="@item.ImageUrl" alt="@item.Name" class="rounded-3 me-3" style="width: 80px; height: 50px; object-fit: cover; border: 1px solid #eee;" />
                                    <div>
                                        <h6 class="mb-0 fw-bold">@item.Name</h6>
                                        <small class="text-muted">موديل @item.Year</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge" style="background-color: rgba(180, 42, 145, 0.1); color: var(--accent-color);">
                                    @item.Category
                                </span>
                            </td>
                            <td class="fw-bold text-success">@item.DailyPrice.ToString("0.00") ر.س</td>
                            <td class="fw-bold text-info">@item.MonthlyPrice.ToString("0.00") ر.س</td>
                            <td>
                                @if (item.IsAvailable)
                                {
                                    <span class="badge bg-success rounded-pill px-3 py-2"><i class="fa-solid fa-check me-1"></i> متاح</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger rounded-pill px-3 py-2"><i class="fa-solid fa-xmark me-1"></i> غير متاح</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-circle" title="تعديل">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('هل أنت متأكد من رغبتك في حذف هذه السيارة؟');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle" title="حذف">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="fa-solid fa-car-side fs-1 mb-3"></i>
                            <h5>لا توجد سيارات مضافة حالياً</h5>
                            <p>قم بإضافة سيارتك الأولى الآن من خلال الزر أعلاه.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>