@model IEnumerable<AlMahaRental.Models.Booking>
@{
    ViewData["Title"] = "إدارة الحجوزات";
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <h2 class="page-title fs-3">سجل الحجوزات</h2>
    <span class="badge rounded-pill px-4 py-2 fs-6 text-white shadow-sm" style="background: var(--accent-gradient);">إجمالي الحجوزات: @Model.Count()</span>
</div>

<div class="table-responsive pb-4">
    <table class="custom-table">
        <thead>
            <tr>
                <th>رقم المرجع</th>
                <th>العميل</th>
                <th>تفاصيل السيارة والتواريخ</th>
                <th>الإجمالي</th>
                <th>الحالة</th>
                <th class="text-center">الإجراءات</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bolder fs-5 text-dark font-monospace bg-light d-inline-block px-3 py-1 rounded-3 border">
                                #@item.BookingReference
                            </div>
                            <div class="text-muted small mt-2 fw-bold"><i class="fa-regular fa-clock me-1"></i> @item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
                        </td>
                        <td>
                            <h6 class="mb-1 fw-bold text-dark">@(item.User?.FirstName + " " + item.User?.LastName)</h6>
                            <span class="badge bg-secondary bg-opacity-10 text-secondary border"><i class="fa-regular fa-id-card me-1"></i> @item.User?.IdNumber</span>
                        </td>
                        <td>
                            <h6 class="fw-bold mb-1" style="color: var(--primary-color);">@item.Car?.Name</h6>
                            <small class="text-muted fw-bold d-block"><i class="fa-solid fa-arrow-right-from-bracket text-success me-1"></i> @item.PickupDate.ToString("dd/MM/yyyy")</small>
                            <small class="text-muted fw-bold d-block"><i class="fa-solid fa-arrow-right-to-bracket text-danger me-1"></i> @item.ReturnDate.ToString("dd/MM/yyyy")</small>
                        </td>
                        <td>
                            <h5 class="fw-bold text-success mb-0">@item.TotalPrice.ToString("0") ر.س</h5>
                        </td>
                        <td>
                            @if (item.Status == "Pending")
                            {
                                <span class="status-badge bg-warning text-dark"><i class="fa-solid fa-hourglass-half"></i> قيد المراجعة</span>
                            }
                            else if (item.Status == "Confirmed")
                            {
                                <span class="status-badge bg-primary text-white"><i class="fa-solid fa-check"></i> مؤكد</span>
                            }
                            else if (item.Status == "Completed")
                            {
                                <span class="status-badge bg-success text-white"><i class="fa-solid fa-flag-checkered"></i> مكتمل</span>
                            }
                            else if (item.Status == "Cancelled")
                            {
                                <span class="status-badge bg-danger text-white"><i class="fa-solid fa-xmark"></i> ملغي</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="dropdown">
                                <button class="btn btn-light shadow-sm rounded-circle" type="button" data-bs-toggle="dropdown" style="width: 45px; height: 45px;">
                                    <i class="fa-solid fa-ellipsis-vertical text-dark"></i>
                                </button>
                                <ul class="dropdown-menu border-0 shadow-lg rounded-4 p-2">
                                    <li>
                                        <form asp-action="ChangeStatus" method="post">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="newStatus" value="Confirmed" />
                                            <button type="submit" class="dropdown-item text-primary fw-bold py-2 rounded-3"><i class="fa-solid fa-check-circle me-2"></i> تأكيد الحجز</button>
                                        </form>
                                    </li>
                                    <li>
                                        <form asp-action="ChangeStatus" method="post">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="newStatus" value="Completed" />
                                            <button type="submit" class="dropdown-item text-success fw-bold py-2 rounded-3"><i class="fa-solid fa-flag-checkered me-2"></i> إنهاء وتسليم</button>
                                        </form>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-action="ChangeStatus" method="post">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="newStatus" value="Cancelled" />
                                            <button type="submit" class="dropdown-item text-danger fw-bold py-2 rounded-3"><i class="fa-solid fa-ban me-2"></i> إلغاء الحجز</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr style="background: transparent !important; box-shadow: none !important;">
                    <td colspan="6" class="text-center py-5 text-muted">
                        <i class="fa-solid fa-calendar-xmark fs-1 mb-3 opacity-50"></i>
                        <h4>لا توجد حجوزات مسجلة في النظام</h4>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>