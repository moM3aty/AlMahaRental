@model IEnumerable<AlMahaRental.Models.BranchLocation>
@{
    ViewData["Title"] = "إدارة مواقع الفروع";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold" style="color: var(--text-main);">مواقع وفروع الشركة المتاحة</h2>
    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 text-white fw-bold shadow-sm" style="background: var(--accent-gradient); border: none;">
        <i class="fa-solid fa-plus me-2"></i> إضافة فرع جديد
    </a>
</div>

<div class="premium-card p-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th scope="col" class="ps-4">اسم الفرع</th>
                    <th scope="col">رقم الجوال</th>
                    <th scope="col">أوقات الدوام</th>
                    <th scope="col" class="text-center">الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var loc in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-dark">
                                <i class="fa-solid fa-location-dot text-primary me-2"></i> @loc.Name
                            </td>
                            <td><span class="badge bg-light text-dark border">@loc.PhoneNumber</span></td>
                            <td class="text-muted small">@loc.WorkingHours</td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@loc.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-bold me-2">
                                    <i class="fa-solid fa-pen me-1"></i> تعديل
                                </a>
                                <form asp-action="Delete" asp-route-id="@loc.Id" method="post" class="d-inline" onsubmit="return confirm('هل أنت متأكد من رغبتك في حذف هذا الفرع؟');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-bold">
                                        <i class="fa-solid fa-trash me-1"></i> حذف
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <i class="fa-solid fa-map-location-dot fs-1 mb-3 opacity-50"></i>
                            <h5>لم تقم بإضافة أي فروع حتى الآن</h5>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>