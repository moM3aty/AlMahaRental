@model AlMahaRental.Models.BranchLocation
@{
    ViewData["Title"] = "إضافة فرع جديد";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold" style="color: var(--text-main);">إضافة موقع فرع جديد</h2>
    <a asp-action="Index" class="btn btn-secondary rounded-pill px-4 shadow-sm">
        <i class="fa-solid fa-arrow-right me-2"></i> عودة للقائمة
    </a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="premium-card p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger fw-bold mb-3"></div>

                <div class="form-group mb-4">
                    <label asp-for="Name" class="form-label fw-bold">اسم الفرع الجديد <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control form-control-lg bg-light border-0" placeholder="مثال: مطار الملك خالد الدولي" required />
                    <span asp-validation-for="Name" class="text-danger small mt-1"></span>
                    <small class="text-muted d-block mt-2">
                        <i class="fa-solid fa-circle-info text-primary me-1"></i>
                        هذا الاسم سيظهر للعميل في قائمة اختيارات "موقع الاستلام" و "موقع التسليم" في صفحة الحجز.
                    </small>
                </div>

                <button type="submit" class="btn w-100 py-3 text-white fw-bold shadow" style="background: var(--accent-gradient); border-radius: 12px; font-size: 1.1rem;">
                    <i class="fa-solid fa-save me-2"></i> حفظ الموقع الجديد
                </button>
            </form>
        </div>
    </div>
</div>