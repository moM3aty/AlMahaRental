@model IEnumerable<AlMahaRental.Models.ApplicationUser>
@{
    ViewData["Title"] = "إدارة المستخدمين";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold" style="color: var(--text-main);">العملاء والمستخدمين المسجلين</h2>
    <span class="badge bg-success fs-6 px-3 py-2 rounded-pill">إجمالي المسجلين: @Model.Count()</span>
</div>

<div class="premium-card p-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th scope="col" class="ps-4">الاسم الكامل</th>
                    <th scope="col">رقم الهوية</th>
                    <th scope="col">رقم الجوال</th>
                    <th scope="col">تاريخ التسجيل</th>
                    <th scope="col" class="text-center">إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center me-3 text-white fw-bold"
                                         style="width: 45px; height: 45px; background: var(--accent-gradient);">
                                        @(user.FirstName.Substring(0, 1))@(user.LastName.Substring(0, 1))
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-bold">@user.FirstName @user.LastName</h6>
                                        <small class="text-muted">@user.Email</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="fw-bold font-monospace">@user.IdNumber</span>
                            </td>
                            <td>
                                <span class="text-dark"><i class="fa-solid fa-phone ms-1 text-muted"></i> @user.PhoneNumber</span>
                            </td>
                            <td class="text-muted fw-semibold">
                                @user.CreatedAt.ToString("yyyy-MM-dd")
                            </td>
                            <td class="text-center">
                                <form asp-action="Delete" asp-route-id="@user.Id" method="post" onsubmit="return confirm('هل أنت متأكد من رغبتك في حذف هذا المستخدم نهائياً؟');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle" title="حذف العميل">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="fa-solid fa-users-slash fs-1 mb-3"></i>
                            <h5>لا يوجد مستخدمين مسجلين في النظام بعد</h5>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>