@model IEnumerable<AlMahaRental.Models.SystemNotification>
@{
    ViewData["Title"] = "المركز الموحد للإشعارات";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold page-title fs-3 mb-0">سجل الإشعارات</h2>

    @if (Model != null && Model.Any(n => !n.IsRead))
    {
        <form asp-action="MarkAllAsRead" method="post">
            <button type="submit" class="btn btn-outline-primary rounded-pill px-4 fw-bold shadow-sm">
                <i class="fa-solid fa-check-double me-2"></i> تحديد الكل كمقروء
            </button>
        </form>
    }
</div>

<div class="row g-3">
    @if (Model != null && Model.Any())
    {
        foreach (var notification in Model)
        {
            <div class="col-12">
                <div class="premium-card p-4 d-flex align-items-center justify-content-between @(!notification.IsRead ? "border-start border-4 border-primary" : "opacity-75")" style="transition: all 0.3s ease;">
                    <div class="d-flex align-items-center gap-4">
                        <div class="rounded-circle d-flex align-items-center justify-content-center text-white"
                             style="width: 55px; height: 55px; font-size: 1.5rem; background: @(!notification.IsRead ? "var(--accent-gradient)" : "#6c757d");">
                            @if (notification.Type == "Booking")
                            {
                                <i class="fa-solid fa-calendar-check"></i>
                            }
                            else if (notification.Type == "User")
                            {

                                <i class="fa-solid fa-user-plus"></i>
                            }
                            else
                            {

                                <i class="fa-solid fa-envelope"></i>
                            }
                        </div>
                        <div>
                            <h5 class="fw-bold text-dark mb-1">
                                @notification.Title
                                @if (!notification.IsRead)
                                {
                                    <span class="badge bg-danger ms-2" style="font-size: 0.7rem;">جديد</span>
                                }
                            </h5>
                            <p class="text-muted mb-1 fs-6">@notification.Message</p>
                            <small class="text-secondary fw-bold"><i class="fa-regular fa-clock me-1"></i> @notification.CreatedAt.ToString("yyyy-MM-dd hh:mm tt")</small>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <a href="@notification.LinkUrl" class="btn btn-light text-primary rounded-pill px-3 shadow-sm fw-bold">
                            الذهاب للتفاصيل <i class="fa-solid fa-arrow-up-right-from-square ms-1"></i>
                        </a>

                        @if (!notification.IsRead)
                        {
                            <form asp-action="MarkAsRead" method="post">
                                <input type="hidden" name="id" value="@notification.Id" />
                                <button type="submit" class="btn btn-primary rounded-pill px-3 shadow-sm fw-bold" style="background: var(--accent-gradient); border: none;" title="تحديد كمقروء">
                                    <i class="fa-solid fa-check"></i>
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <div class="premium-card py-5">
                <i class="fa-regular fa-bell-slash fs-1 text-muted mb-3 opacity-50"></i>
                <h4 class="text-muted">لا توجد إشعارات حالياً</h4>
            </div>
        </div>
    }
</div>